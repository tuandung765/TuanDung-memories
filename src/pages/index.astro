---
import Layout from '../layouts/Layout.astro';
import NoteGallery from '../components/NoteGallery.jsx';
---
<Layout title="Lưu Bút Lớp 9 💕 — Tình Yêu Học Đường">

  <!-- HERO -->
  <section class="relative min-h-[88vh] flex items-center overflow-hidden">
    <div class="absolute inset-0 lined-paper opacity-25 pointer-events-none"></div>
    <div class="absolute top-16 right-12 text-7xl opacity-8 animate-float select-none">💌</div>
    <div class="absolute bottom-24 left-16 text-5xl opacity-8 animate-float select-none" style="animation-delay:2s">🌸</div>
    <div class="absolute top-1/2 right-1/4 text-4xl opacity-6 animate-float select-none" style="animation-delay:3.5s">💕</div>

    <div class="max-w-6xl mx-auto px-6 py-20 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div>
        <span class="badge-class mb-6 inline-block" style="color:#FF2D77;">💕 Lưu Bút Tình Yêu Lớp 9</span>
        <h1 class="font-playfair text-5xl sm:text-6xl lg:text-7xl font-bold leading-[1.1] mb-6" style="color:#3D1530;">
          Những Trang<br/>
          <em class="not-italic text-gradient-love">Lưu Bút</em><br/>
          <span class="text-4xl sm:text-5xl">Ngọt Ngào Nhất</span>
        </h1>
        <p class="font-lora text-lg leading-relaxed mb-10 max-w-md opacity-80">
          Cuối năm lớp 9, khi sắp phải chia tay — hãy ghi lại những điều bạn chưa kịp nói,
          những cảm xúc chưa kịp bày tỏ. Vì có những khoảnh khắc chỉ xảy ra một lần.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/viet-luu-but" class="btn-love text-base tracking-wider">✍️ Viết Lưu Bút Ngay</a>
          <a href="/bo-suu-tap"
             class="flex items-center gap-2 px-7 py-3 border-2 font-crimson tracking-wider text-base transition-all duration-300 hover:bg-pink-50 rounded-sm"
             style="border-color:rgba(255,45,119,.4);color:#CC0055;">
            📖 Xem Bộ Sưu Tập
          </a>
        </div>
        <div class="flex gap-8 mt-12 pt-8 border-t border-pink-200/50">
          {[{num:'1,200+',label:'Trang Lưu Bút'},{num:'300+',label:'Trường Học'},{num:'Vô số',label:'Kỷ Niệm'}].map(({num,label})=>(
            <div>
              <p class="font-playfair text-2xl font-bold" style="color:#CC0055;">{num}</p>
              <p class="font-crimson text-xs tracking-widest uppercase opacity-60">{label}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Stacked cards -->
      <div class="relative h-[460px] hidden lg:block">
        <div class="card-diary absolute top-10 right-0 w-72 p-6 opacity-50" style="transform:rotate(7deg);">
          <p class="font-dancing text-2xl" style="color:#FF94BB;">Gửi người ấy...</p>
        </div>
        <div class="card-diary absolute top-2 right-6 w-80 p-7 opacity-80" style="transform:rotate(-4deg);">
          <div class="tape-pink" style="top:-10px;right:40px;"></div>
          <p class="font-dancing text-lg leading-relaxed" style="color:#CC0055;">
            "Mình thích bạn từ hồi lớp 7 mà chưa bao giờ dám nói..."
          </p>
        </div>
        <div class="card-diary absolute top-0 left-0 p-8" style="width:340px;transform:rotate(-1deg);box-shadow:0 8px 32px rgba(255,45,119,.18);">
          <div class="tape-pink" style="top:-10px;left:50px;"></div>
          <div class="flex items-start justify-between mb-5">
            <div>
              <p class="font-dancing text-2xl font-bold" style="color:#CC0055;">Lưu Bút Cuối Năm</p>
              <p class="font-crimson text-xs tracking-widest uppercase opacity-60">Lớp 9A • Năm 2024</p>
            </div>
            <div class="heart-seal text-xl">💌</div>
          </div>
          <div class="lined-paper px-1">
            <p class="font-lora text-sm italic leading-7 opacity-85">
              "Cảm ơn bạn đã là phần đẹp nhất của những năm tháng lớp 9 của mình.
              Dù sau này mỗi người một ngả, mình vẫn sẽ luôn nhớ nụ cười của bạn..."
            </p>
          </div>
          <div class="flex items-center justify-between mt-5 pt-4 border-t border-pink-200/40">
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 rounded-full flex items-center justify-center text-white text-sm font-bold" style="background:linear-gradient(135deg,#FF6FAE,#CC0055);">M</div>
              <div>
                <p class="font-dancing text-base font-semibold leading-none" style="color:#CC0055;">Minh Anh</p>
                <p class="font-crimson text-[10px] opacity-50">20/05/2024</p>
              </div>
            </div>
            <span class="text-lg animate-heartbeat">💕</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="py-24 px-6" style="background:linear-gradient(180deg,#FFF8FB,#FFE8F2);">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="font-playfair text-4xl sm:text-5xl font-bold" style="color:#3D1530;">
          Chỉ <em class="text-gradient-love">3 Bước</em> Thôi
        </h2>
        <p class="font-crimson text-lg mt-4 opacity-70">Đơn giản như viết một bức thư tay</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {icon:'💭',step:'01',title:'Nghĩ Đến Người Ấy',desc:'Nhắm mắt lại, nghĩ đến người bạn muốn gửi lưu bút — những kỷ niệm, những cảm xúc bạn muốn nói.',color:'from-pink-50 to-rose-50'},
          {icon:'✍️',step:'02',title:'Viết Từ Trái Tim',desc:'Gõ những điều bạn chưa bao giờ dám nói trực tiếp. Chọn font, màu sắc và sticker yêu thích.',color:'from-purple-50 to-pink-50'},
          {icon:'💌',step:'03',title:'Gửi & Lưu Mãi Mãi',desc:'Chia sẻ link cho người ấy hoặc lưu làm kỷ niệm. Trang lưu bút của bạn sẽ tồn tại vĩnh viễn.',color:'from-rose-50 to-pink-50'},
        ].map(({icon,step,title,desc,color},i)=>(
          <div class={`card-diary p-8 bg-gradient-to-br ${color} relative group hover:-translate-y-1 transition-all duration-300`} style={`animation-delay:${i*.15}s`}>
            <div class="tape-pink" style="top:-10px;left:30px;"></div>
            <span class="font-playfair text-7xl font-bold absolute top-4 right-5 leading-none select-none" style="color:rgba(255,45,119,.1);">{step}</span>
            <div class="text-4xl mb-5">{icon}</div>
            <h3 class="font-playfair text-xl font-bold mb-3" style="color:#3D1530;">{title}</h3>
            <p class="font-lora text-sm leading-relaxed opacity-75">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-end justify-between mb-12">
        <div>
          <span class="badge-class mb-3 inline-block" style="color:#FF2D77;">Mới Nhất</span>
          <h2 class="font-playfair text-4xl font-bold" style="color:#3D1530;">Lưu Bút Nổi Bật 💕</h2>
        </div>
        <a href="/bo-suu-tap" class="hidden sm:block font-crimson text-sm underline underline-offset-4 transition" style="color:#FF2D77;">Xem tất cả →</a>
      </div>
      <NoteGallery client:load />
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="py-24 px-6 relative overflow-hidden" style="background:#FFE8F2;">
    <div class="absolute inset-0 lined-paper opacity-15 pointer-events-none"></div>
    <div class="max-w-5xl mx-auto relative z-10">
      <h2 class="font-playfair text-4xl font-bold text-center mb-14" style="color:#3D1530;">
        Họ Đã Nói Gì? 🌸
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {quote:'Mình gửi lưu bút cho crush qua trang này và bạn ấy đã reply lại. Giờ tụi mình đang yêu nhau rồi 😭💕',name:'Ngọc Hân',info:'Lớp 9A2 — Hà Nội',emoji:'🌸',rotate:'-2deg'},
          {quote:'Đọc lại lưu bút năm lớp 9 mà khóc không ngừng. Cảm ơn trang này đã giúp mình lưu lại ký ức đẹp nhất đời học sinh.',name:'Tuấn Kiệt',info:'Cựu HS lớp 9 — TP.HCM',emoji:'💙',rotate:'1.5deg'},
          {quote:'Cả lớp mình đều dùng Lưu Bút 9 để viết cho nhau trước khi lên cấp 3. Xúc động lắm, ai cũng khóc hết!',name:'Thu Trang',info:'Lớp 9B — Đà Nẵng',emoji:'💜',rotate:'-1deg'},
        ].map(({quote,name,info,emoji,rotate})=>(
          <div class="card-diary p-7 relative" style={`transform:rotate(${rotate});`}>
            <div class="tape-pink" style="top:-10px;left:35px;"></div>
            <div class="text-4xl mb-4 opacity-25 font-playfair select-none" style="color:#FF2D77;">"</div>
            <p class="font-lora text-sm leading-relaxed italic mb-6 opacity-85">{quote}</p>
            <div class="flex items-center gap-3 pt-4 border-t border-pink-200/50">
              <div class="heart-seal w-10 h-10 text-lg">{emoji}</div>
              <div>
                <p class="font-dancing text-lg font-semibold leading-tight" style="color:#CC0055;">{name}</p>
                <p class="font-crimson text-[11px] tracking-wide opacity-60">{info}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-6 mx-6 mb-16 rounded-sm relative overflow-hidden text-center"
           style="background:linear-gradient(135deg,#CC0055,#FF2D77,#8B4FE8);">
    <div class="absolute inset-0 lined-paper opacity-10 pointer-events-none"></div>
    <div class="relative z-10 max-w-2xl mx-auto">
      <p class="font-dancing text-pink-200 text-2xl mb-2">Đừng để lời chưa nói mãi im lặng...</p>
      <h2 class="font-playfair text-4xl sm:text-5xl font-bold text-white mb-5 leading-tight">
        Hôm Nay, Hãy Viết<br/>Cho Người Ấy 💕
      </h2>
      <p class="font-crimson text-pink-100 text-lg mb-10 opacity-90">
        Miễn phí 100%. Không cần đăng ký. Chỉ cần dũng cảm một chút thôi.
      </p>
      <a href="/viet-luu-but"
         class="inline-flex items-center gap-2 px-10 py-4 bg-white font-crimson font-semibold tracking-wider text-base rounded-sm transition-all duration-300 hover:shadow-xl hover:-translate-y-1"
         style="color:#CC0055;">
        ✍️ Viết Lưu Bút Ngay — Miễn Phí
      </a>
    </div>
  </section>

</Layout>
