---
import Layout from '../layouts/Layout.astro';
import NoteGallery from '../components/NoteGallery.jsx';
---
<Layout title="Bộ Sưu Tập Lưu Bút 💕 — Lớp 9">
  <div class="py-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <span class="badge-class mb-4 inline-block" style="color:#FF2D77;">📖 Bộ Sưu Tập</span>
        <h1 class="font-playfair text-5xl sm:text-6xl font-bold mt-3 mb-5" style="color:#3D1530;">
          Những Trang Lưu Bút<br/>
          <em class="text-gradient-love font-normal">Ngọt Ngào Nhất</em>
        </h1>
        <p class="font-lora text-lg max-w-xl mx-auto leading-relaxed opacity-75">
          Hàng ngàn trang lưu bút từ các bạn học sinh lớp 9 khắp Việt Nam.
          Mỗi trang là một câu chuyện tình yêu học đường chưa kịp nói.
        </p>
      </div>

      <div class="max-w-lg mx-auto mb-14">
        <div class="relative">
          <input type="search" placeholder="Tìm theo tên, trường, lớp..."
            class="w-full pl-12 pr-5 py-4 font-crimson text-base border-2 focus:outline-none transition-colors rounded-sm"
            style="background:rgba(255,248,251,.8);border-color:rgba(255,45,119,.3);color:#3D1530;"/>
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5" style="color:#FF2D77;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </div>
      </div>

      <NoteGallery client:load />

      <div class="mt-20 text-center">
        <p class="font-dancing text-4xl mb-3" style="color:#CC0055;">"Tình yêu đầu đời đẹp nhất vì nó trong sáng nhất."</p>
        <p class="font-crimson text-sm tracking-widest uppercase opacity-50">— Ký Ức Lớp 9</p>
      </div>
    </div>
  </div>
</Layout>
